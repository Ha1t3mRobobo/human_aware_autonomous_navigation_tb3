<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
<xacro:include filename="inertial_macros.xacro" />

<!-- Cette description est juste une démo pour le robot et non la description finale -->


<!--material-->

<material name="Blue">
    <color rgba="0.15 0.39 0.96 1" />
</material>

<material name="Cyan">
    <color rgba="0.05 1 0.98 0.8" />
</material>

<material name="Pink">
    <color rgba="1 0.09 0.61 0.8" />
</material>

<material name="Purple">
    <color rgba="0.67 0 0.8 0.8" />
</material>

<material name="Green">
    <color rgba="0.29 0.9 0.22 0.8" />
</material>

<material name="Gold">
    <color rgba="0.72 0.67 0.23 0.8" />
</material>

<material name="Red">
    <color rgba="0.94 0.23 0.23 0.8" />
</material>

<material name="Grey">
    <color rgba="0.5 0.5 0.5 1" />
</material>

<material name="White">
    <color rgba="0.9 0.8 0.8 1" />
</material>

<material name="Black">
    <color rgba="0.1 0.1 0.1 1" />
</material>


<link name="base_footprint"></link>
<joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.1" rpy="0 0 0" />
</joint>



<!--Links/Joints-->
<!--Base_link-->
<link name="base_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.25 0.10" />
        </geometry>
        <material name="White">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.25 0.10" />
        </geometry>
    </collision>

    <xacro:inertial_box mass="2.0" x="0.25" y="0.25" z="0.10" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_box>
</link>
<gazebo reference="base_link">
  <material>Gazebo/White</material>
</gazebo>

<!--.........................................................................................-->


<!--left wheel-->
<link name="left_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
            <cylinder radius="0.05" length="0.03" />
        </geometry>
        <material name="Black">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
            <cylinder radius="0.05" length="0.03" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="0.05" length="0.02" >
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="left_wheel_link" />
    <origin xyz="0.0625 0.14 -0.05" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    <axis xyz="0 1 0" />
</joint>

<gazebo reference="left_wheel_link">
  <material>Gazebo/Black</material>
  <mu1>0.5</mu1>
  <mu2>0.5</mu2>
</gazebo>

<!--right wheel-->
<link name="right_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
            <cylinder radius="0.05" length="0.03" />
        </geometry>
        <material name="Black">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
            <cylinder radius="0.05" length="0.03" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="0.05" length="0.02" >
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="right_wheel_link" />
    <origin xyz="0.0625 -0.14 -0.05" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    <axis xyz="0 1 0" />
</joint>

<gazebo reference="right_wheel_link">
  <material>Gazebo/Black</material>
  <mu1>0.5</mu1>
  <mu2>0.5</mu2>
  
</gazebo>

<!--caster_wheel-->
<link name="caster_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <sphere radius="0.025" />
        </geometry>
        <material name="Black">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <sphere radius="0.025" />
        </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.2" radius="0.025">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
</link>

<joint name="caster_wheel_base_joint" type="fixed">
    <parent link="base_link" />
    <child link="caster_wheel_link" />
    <origin xyz="-0.1 0 -0.075" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    </joint>

<gazebo reference="caster_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>0.005</mu1>
    <mu2>0.005</mu2>
</gazebo>


</robot>