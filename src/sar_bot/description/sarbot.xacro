<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
<xacro:include filename="inertial_macros.xacro" />

<!-- Cette description est juste une démo pour le robot et non la description finale -->


<!--material-->

<material name="Blue">
    <color rgba="0.15 0.39 0.96 1" />
</material>

<material name="Cyan">
    <color rgba="0.05 1 0.98 0.8" />
</material>

<material name="Pink">
    <color rgba="1 0.09 0.61 0.8" />
</material>

<material name="Purple">
    <color rgba="0.67 0 0.8 0.8" />
</material>

<material name="Green">
    <color rgba="0.29 0.9 0.22 0.8" />
</material>

<material name="Gold">
    <color rgba="0.72 0.67 0.23 0.8" />
</material>

<material name="Red">
    <color rgba="0.94 0.23 0.23 0.8" />
</material>

<material name="Grey">
    <color rgba="0.5 0.5 0.5 1" />
</material>

<material name="White">
    <color rgba="0.9 0.8 0.8 1" />
</material>

<material name="Black">
    <color rgba="0.1 0.1 0.1 1" />
</material>
<!--Links/Joints-->

<!--base_footprint-->
<link name="base_footprint"></link>
<joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.015" rpy="0 0 0" />
</joint>


<!--Base_link-->
<link name="base_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.20 0.01" />
        </geometry>
        <material name="White">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.20 0.01" />
        </geometry>
    </collision>

    <xacro:inertial_box mass="1.35" x="0.25" y="0.2" z="0.01" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_box>
</link>
<gazebo reference="base_link">
  <material>Gazebo/White</material>
</gazebo>

<!--.........................................................................................-->


<!--remarque : Dans cette description, on essaie de s’approcher le plus possible d’un robot réel -->

<!--Moteur et encodeur -->

<!--moteur gauche-->
<link name="left_enc_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.025 0.025 0.025" />
        </geometry>
        <material name="Blue">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.025 0.025 0.025" />
        </geometry>
    </collision>

    <xacro:inertial_box mass="0.15" x="0.025" y="0.025" z="0.025" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_box>
</link>

<joint name="Left_enc_joint" type="fixed">
    <parent link="base_link" />
    <child link="left_enc_link" />
    <origin xyz="0.0725 0.0775 0.013" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>

<gazebo reference="lef_enc_link">
  <material>Gazebo/Blue</material>
</gazebo>

<!--moteur droite-->
<link name="right_enc_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.025 0.025 0.025" />
        </geometry>
        <material name="Blue">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.025 0.025 0.025" />
        </geometry>
    </collision>

    <xacro:inertial_box mass="0.15" x="0.025" y="0.025" z="0.025" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_box>
</link>

<joint name="right_enc_joint" type="fixed">
    <parent link="base_link" />
    <child link="right_enc_link" />
    <origin xyz="0.0725 -0.0775 0.013" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>

<gazebo reference="right_enc_link">
  <material>Gazebo/Red</material>
</gazebo>

<!--.........................................................................................-->


<!-- left motor out cylinder-->
<link name="left_cy_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.02" />
        </geometry>
        <material name="Gold">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.01" length="0.02" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.01" radius="0.01" length="0.02" >
        <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="left_cy_joint" type="fixed">
    <parent link="left_enc_link" />
    <child link="left_cy_link" />
    <origin xyz="0 0.02 0" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>

<gazebo reference="left_cy_link">
  <material>Gazebo/Yellow</material>
</gazebo>

<!-- right motor out cylinder-->
<link name="right_cy_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.02" />
        </geometry>
        <material name="Gold">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.01" length="0.02" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.01" radius="0.01" length="0.02" >
        <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="right_cy_joint" type="fixed">
    <parent link="right_enc_link" />
    <child link="right_cy_link" />
    <origin xyz="0 -0.02 0" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>

<gazebo reference="right_cy_link">
  <material>Gazebo/Yellow</material>
</gazebo>


<!--.........................................................................................-->


<!--left wheel-->
<link name="left_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.03" length="0.02" />
        </geometry>
        <material name="Black">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.03" length="0.02" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="0.03" length="0.02" >
        <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="left_wheel_joint" type="continuous">
    <parent link="left_cy_link" />
    <child link="left_wheel_link" />
    <origin xyz="0 0.015 0" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    <axis xyz="0 1 0" />
</joint>

<gazebo reference="left_wheel_link">
  <material>Gazebo/Black</material>
  <mu1>0.5</mu1>
  <mu2>0.5</mu2>
</gazebo>

<!--right wheel-->
<link name="right_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.03" length="0.02" />
        </geometry>
        <material name="Black">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="1.57 0 0" />
        <geometry>
            <cylinder radius="0.03" length="0.02" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.3" radius="0.03" length="0.02" >
        <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
</link>
<joint name="right_wheel_joint" type="continuous">
    <parent link="right_cy_link" />
    <child link="right_wheel_link" />
    <origin xyz="0 -0.015 0" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    <axis xyz="0 1 0" />
</joint>

<gazebo reference="right_wheel_link">
  <material>Gazebo/Black</material>
  <mu1>0.5</mu1>
  <mu2>0.5</mu2>
</gazebo>

<!--caster_wheel-->
<link name="caster_wheel_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <sphere radius="0.05" />
        </geometry>
        <material name="Red">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <sphere radius="0.05" />
        </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.1" radius="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
</link>

<joint name="caster_wheel_base_joint" type="fixed">
    <parent link="base_link" />
    <child link="caster_wheel_link" />
    <origin xyz="-0.0825 0 -0.05" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
    </joint>

<gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
</gazebo>

<!--.........................................................................................-->

<!--upper_chassis-->
<link name="roof_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.20 0.01" />
        </geometry>
        <material name="White">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.25 0.20 0.01" />
        </geometry>
    </collision>

    <xacro:inertial_box mass="1.35" x="0.25" y="0.2" z="0.01" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_box>
</link>

<joint name="roof_base_joint" type="fixed">
    <parent link="base_link" />
    <child link="roof_link" />
    <origin xyz="0 0 0.03" rpy="0 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>

<gazebo reference="roof_link">
  <material>Gazebo/White</material>
</gazebo>

<!--.........................................................................................-->

<!--supprots-->
<!--left_support-->
<link name="left_support_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.025" />
        </geometry>
        <material name="Grey">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.025" />
        </geometry>
    </collision>

    <xacro:inertial_cylinder mass="0.15" radius="0.002" length="0.025" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_cylinder>
</link>

<joint name="left_support_joint" type="fixed">
    <parent link="base_link" />
    <child link="left_support_link" />
    <origin xyz="-0.0725 0.0775 0.013" rpy="0 0 0" />
</joint>

<gazebo reference="left_support_link">
  <material>Gazebo/Grey</material>
</gazebo>

<!--right support-->

<link name="right_support_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.025" />
        </geometry>
        <material name="Grey">
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.002" length="0.025" />
        </geometry>
    </collision>

    <xacro:inertial_cylinder mass="0.15" radius="0.002" length="0.025" >
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_cylinder>
</link>

<joint name="right_support_joint" type="fixed">
    <parent link="base_link" />
    <child link="right_support_link" />
    <origin xyz="-0.0725 -0.0775 0.013" rpy="0 0 0" />
</joint>

<gazebo reference="right_support_link">
  <material>Gazebo/Grey</material>
</gazebo>


</robot>